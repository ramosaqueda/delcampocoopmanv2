---
import { getCollection } from "astro:content";

const testimonials = await getCollection("testimonials");
const clients = await getCollection("clients");

// Duplicate clients for seamless infinite scroll
const marqueeClients = [...clients, ...clients];
---

<section class="py-24 bg-white overflow-hidden relative" id="clients">
    <div class="layout-container px-6 md:px-10 max-w-[1280px] mx-auto mb-20">
        <div class="text-center mb-16">
            <span
                class="text-primary text-sm font-bold uppercase tracking-widest mb-2 block"
            >
                Confianza & Excelencia
            </span>
            <h2
                class="font-serif text-3xl md:text-5xl font-bold text-secondary-blue"
            >
                Nuestros Clientes
            </h2>
        </div>

        <!-- Testimonials Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
            {
                testimonials.map((testimonial) => (
                    <div class="p-8 bg-background-light rounded-xl border border-accent-silver/50 hover:shadow-lg transition-shadow">
                        <div class="text-primary mb-6">
                            <span class="material-symbols-outlined text-4xl">
                                format_quote
                            </span>
                        </div>
                        <p class="text-slate-600 text-lg leading-relaxed italic mb-6">
                            "{testimonial.data.quote}"
                        </p>
                        <div>
                            <h4 class="font-serif text-lg font-bold text-secondary-blue">
                                {testimonial.data.author}
                            </h4>
                            <span class="text-sm text-slate-500 font-medium">
                                {testimonial.data.position}
                            </span>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>

    <!-- Client Logos Marquee -->
    <div
        class="relative w-full py-10 bg-background-light/50 border-y border-accent-silver/30"
    >
        <div class="flex items-center gap-16 animate-marquee whitespace-nowrap">
            {
                marqueeClients.map((client) => (
                    <div class="flex-shrink-0 grayscale hover:grayscale-0 transition-all opacity-60 hover:opacity-100">
                        <img
                            src={client.data.logo}
                            alt={client.data.name}
                            class="h-12 w-auto object-contain"
                        />
                    </div>
                ))
            }
        </div>
        <!-- Gradient Masks -->
        <div
            class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-white to-transparent pointer-events-none"
        >
        </div>
        <div
            class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-white to-transparent pointer-events-none"
        >
        </div>
    </div>
</section>

<style>
    .animate-marquee {
        animation: marquee 30s linear infinite;
    }

    @keyframes marquee {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }
</style>
