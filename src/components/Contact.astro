---

---

<section class="relative py-24 bg-background-dark/50" id="contact">
  <!-- Background effects -->
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-secondary-blue/20 to-transparent z-0"
  >
  </div>

  <div
    class="layout-container relative z-10 px-6 md:px-10 max-w-[1280px] mx-auto"
  >
    <div class="text-center mb-16">
      <span
        class="text-primary text-sm font-bold uppercase tracking-widest mb-2 block"
        >Contáctenos</span
      >
      <h2 class="font-serif text-3xl md:text-5xl font-bold text-white mb-6">
        Hablemos de su Proyecto
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Complete el formulario y nos pondremos en contacto a la brevedad para
        discutir sus necesidades de compliance.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
      <!-- Contact Info -->
      <div class="space-y-10">
        <div class="glass-panel p-8 rounded-xl border border-white/5">
          <h3 class="font-serif text-2xl font-bold text-white mb-6">
            Información de Contacto
          </h3>
          <p class="text-slate-400 mb-8">
            Estamos aquí para ayudarle. Contáctenos por cualquiera de estos
            medios y responderemos a la brevedad.
          </p>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0"
              >
                <span class="material-symbols-outlined">location_on</span>
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Ubicación</h4>
                <p class="text-slate-400">
                  Huanhuali 565<br />La Serena
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0"
              >
                <span class="material-symbols-outlined">call</span>
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Teléfono</h4>
                <p class="text-slate-400">+56 9 9768 4860</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0"
              >
                <span class="material-symbols-outlined">mail</span>
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Email</h4>
                <p class="text-slate-400">contacto@delcampocoopman.cl</p>
              </div>
            </div>
          </div>
        </div>

        <div class="hidden lg:block">
          <h4 class="font-bold text-white mb-4">¿Por qué contactarnos?</h4>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-slate-300">
              <span class="material-symbols-outlined text-primary text-sm"
                >check_circle</span
              >
              <span>Atención personalizada y directa</span>
            </li>
            <li class="flex items-center gap-3 text-slate-300">
              <span class="material-symbols-outlined text-primary text-sm"
                >check_circle</span
              >
              <span>Expertos en Compliance Penal</span>
            </li>
            <li class="flex items-center gap-3 text-slate-300">
              <span class="material-symbols-outlined text-primary text-sm"
                >check_circle</span
              >
              <span>Respuesta oportuna a crisis</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Contact Form -->
      <div
        class="glass-panel p-8 md:p-10 rounded-xl border border-white/5 relative bg-background-dark/40"
      >
        <h3 class="font-serif text-2xl font-bold text-white mb-6">
          Envíenos su Consulta
        </h3>

        <!-- Success message (hidden by default) -->
        <div
          id="form-success"
          class="hidden p-6 bg-green-900/30 border border-green-500/30 rounded-lg mb-6"
        >
          <div class="flex items-center gap-3 text-green-400">
            <span class="material-symbols-outlined">check_circle</span>
            <div>
              <p class="font-bold">Mensaje enviado correctamente</p>
              <p class="text-sm text-green-300/80">Nos pondremos en contacto a la brevedad.</p>
            </div>
          </div>
        </div>

        <form
          id="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-6"
        >
          <!-- Honeypot field for spam protection -->
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>
              No llenar este campo: <input name="bot-field" />
            </label>
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="name" class="text-sm font-medium text-slate-300"
                >Nombre</label
              >
              <input
                type="text"
                id="name"
                name="name"
                class="w-full px-4 py-3 bg-background-dark/50 border border-white/10 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all text-white placeholder-slate-600"
                placeholder="Juan Pérez"
                required
              />
            </div>
            <div class="space-y-2">
              <label for="email" class="text-sm font-medium text-slate-300"
                >Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-4 py-3 bg-background-dark/50 border border-white/10 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all text-white placeholder-slate-600"
                placeholder="juan@empresa.com"
                required
              />
            </div>
          </div>

          <div class="space-y-2">
            <label for="company" class="text-sm font-medium text-slate-300"
              >Empresa (Opcional)</label
            >
            <input
              type="text"
              id="company"
              name="company"
              class="w-full px-4 py-3 bg-background-dark/50 border border-white/10 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all text-white placeholder-slate-600"
              placeholder="Nombre de su empresa"
            />
          </div>

          <div class="space-y-2">
            <label for="message" class="text-sm font-medium text-slate-300"
              >Mensaje</label
            >
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full px-4 py-3 bg-background-dark/50 border border-white/10 rounded-lg focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all text-white placeholder-slate-600 resize-none"
              placeholder="¿En qué podemos ayudarle?"
              required></textarea>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full py-4 bg-primary hover:bg-primary-hover text-background-dark font-bold text-lg rounded-lg transition-all transform hover:scale-[1.02] shadow-lg shadow-primary/20 disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none"
          >
            <span id="btn-text">Enviar Mensaje</span>
            <span id="btn-loading" class="hidden">
              <span class="inline-flex items-center gap-2">
                <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Enviando...
              </span>
            </span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnLoading = document.getElementById('btn-loading');
  const formSuccess = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Show loading state
    submitBtn?.setAttribute('disabled', 'true');
    btnText?.classList.add('hidden');
    btnLoading?.classList.remove('hidden');

    try {
      const formData = new FormData(form);

      const response = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData as any).toString(),
      });

      if (response.ok) {
        // Show success message
        formSuccess?.classList.remove('hidden');
        form.reset();

        // Hide success message after 5 seconds
        setTimeout(() => {
          formSuccess?.classList.add('hidden');
        }, 5000);
      } else {
        throw new Error('Error al enviar el formulario');
      }
    } catch (error) {
      alert('Hubo un error al enviar el mensaje. Por favor, intente nuevamente.');
    } finally {
      // Reset button state
      submitBtn?.removeAttribute('disabled');
      btnText?.classList.remove('hidden');
      btnLoading?.classList.add('hidden');
    }
  });
</script>
