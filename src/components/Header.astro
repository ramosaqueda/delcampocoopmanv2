<header
  class="fixed top-0 left-0 right-0 z-50 glass-panel border-b border-white/10 transition-all duration-300"
>
  <div class="layout-container flex justify-center w-full">
    <div
      class="max-w-[1280px] w-full px-6 lg:px-10 h-20 flex items-center justify-between"
    >
      <div class="flex items-center gap-3 text-white group cursor-pointer">
        <span class="material-symbols-outlined text-primary text-3xl"
          >balance</span
        >
        <h2
          class="font-serif text-xl md:text-2xl font-bold tracking-wide text-white group-hover:text-primary transition-colors"
        >
          Del Campo Coopman
        </h2>
      </div>
      <nav class="hidden md:flex items-center gap-8">
        <a
          class="text-sm font-medium text-slate-300 hover:text-white hover:underline decoration-primary underline-offset-8 transition-all"
          href="#services">Servicios</a
        >
        <a
          class="text-sm font-medium text-slate-300 hover:text-white hover:underline decoration-primary underline-offset-8 transition-all"
          href="#about">La Firma</a
        >
        <a
          class="text-sm font-medium text-slate-300 hover:text-white hover:underline decoration-primary underline-offset-8 transition-all"
          href="#founder">Fundadora</a
        >
        <a
          class="text-sm font-medium text-slate-300 hover:text-white hover:underline decoration-primary underline-offset-8 transition-all"
          href="#insights">Insights</a
        >
        <a
          class="text-sm font-medium text-slate-300 hover:text-white hover:underline decoration-primary underline-offset-8 transition-all"
          href="#contact">Contacto</a
        >
        <button
          class="flex items-center justify-center rounded-lg h-10 px-6 bg-primary hover:bg-primary-hover text-background-dark text-sm font-bold tracking-wide transition-all transform hover:scale-105 shadow-[0_0_15px_rgba(212,164,17,0.3)]"
        >
          Agendar Consulta
        </button>
      </nav>
      <button class="md:hidden text-white">
        <span class="material-symbols-outlined text-3xl">menu</span>
      </button>
    </div>
  </div>
</header>
