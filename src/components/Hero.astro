---

---

<section
  class="relative min-h-screen w-full flex items-center justify-center pt-20 overflow-hidden"
>
  <div class="absolute inset-0 z-0">
    <div
      class="absolute inset-0 bg-gradient-to-b from-background-dark/80 via-background-dark/60 to-background-dark z-10"
    >
    </div>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-blue-900/40 to-transparent z-10"
    >
    </div>
    <div
      class="h-full w-full bg-cover bg-center bg-no-repeat opacity-50"
      data-alt="Modern abstract office architecture with glass facades representing transparency and corporate structure"
      style="
        background-image: url('/images/hero-bg.jpg');
      "
    >
    </div>
  </div>
  <div
    class="relative z-20 layout-container flex flex-col items-center justify-center w-full px-6 md:px-10 max-w-[1280px]"
  >
    <div
      class="glass-panel p-8 md:p-12 rounded-2xl max-w-4xl w-full text-center border border-white/5 shadow-2xl backdrop-blur-xl"
    >
      <span
        class="inline-block py-1 px-3 rounded-full bg-primary/10 border border-primary/30 text-primary text-xs font-bold uppercase tracking-widest mb-6"
      >
        Compliance Legal
      </span>
      <h1
        class="font-serif text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6 text-glow"
      >
        Excelencia y <br />Prevención de Riesgos
      </h1>
      <p
        class="text-slate-300 text-lg md:text-xl font-light leading-relaxed max-w-2xl mx-auto mb-10"
      >
        Convertimos los riesgos legales en oportunidades de fortalecimiento
        corporativo
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <button
          class="w-full sm:w-auto flex items-center justify-center rounded-lg h-12 px-8 bg-primary hover:bg-primary-hover text-background-dark text-base font-bold tracking-wide transition-all shadow-lg hover:shadow-primary/40"
        >
          Agendar Consulta
        </button>
        <button
          class="w-full sm:w-auto flex items-center justify-center rounded-lg h-12 px-8 bg-transparent border border-slate-500 hover:border-white text-white text-base font-medium transition-all hover:bg-white/5"
        >
          Conocer la Firma
        </button>
      </div>
    </div>
  </div>
  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce text-slate-400"
  >
    <span class="material-symbols-outlined">keyboard_arrow_down</span>
  </div>
</section>
