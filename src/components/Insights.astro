---
import { getCollection } from "astro:content";

const insights = await getCollection("insights");
---

<section class="relative py-20 overflow-hidden">
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-secondary-blue to-background-dark z-0"
  >
  </div>
  <div
    class="absolute inset-0 opacity-10"
    style="
      background-image: radial-gradient(#ffffff 1px, transparent 1px);
      background-size: 30px 30px;
    "
  >
  </div>
  <div
    class="layout-container relative z-10 px-6 md:px-10 max-w-[1280px] mx-auto"
  >
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
      <div class="flex-1 space-y-8">
        <div class="flex items-center gap-3 text-primary mb-2">
          <span class="material-symbols-outlined">lock</span>
          <span class="text-sm font-bold tracking-widest uppercase"
            >Confidencialidad Garantizada</span
          >
        </div>
        <h2
          class="font-serif text-4xl lg:text-5xl font-bold text-white leading-tight"
        >
          Canal de Denuncias <br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-white"
            >Ley 20.393</span
          >
        </h2>
        <p class="text-slate-300 text-lg leading-relaxed max-w-xl">
          Nuestra "Bóveda de Seguridad" para reportes confidenciales. Ofrecemos
          una plataforma encriptada que garantiza anonimato total y robustez
          técnica en la gestión de denuncias corporativas.
        </p>
        <ul class="space-y-4 text-slate-400">
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-sm"
              >check_circle</span
            >
            <span>Encriptación de extremo a extremo</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-sm"
              >check_circle</span
            >
            <span>Gestión anónima y trazable</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-sm"
              >check_circle</span
            >
            <span>Cumplimiento normativo integral</span>
          </li>
        </ul>
        <div class="pt-4">
          <button
            class="flex items-center gap-3 rounded-lg h-12 px-8 bg-transparent border border-accent-silver text-white hover:bg-white hover:text-background-dark transition-all font-bold tracking-wide"
          >
            <span class="material-symbols-outlined">vpn_key</span>
            Acceso Seguro
          </button>
        </div>
      </div>
      <div class="flex-1 w-full flex justify-center lg:justify-end">
        <div class="relative w-full max-w-md aspect-square">
          <div class="absolute inset-0 bg-primary/20 blur-[100px] rounded-full">
          </div>
          <div
            class="relative h-full w-full rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md p-8 flex flex-col items-center justify-center text-center shadow-2xl"
          >
            <span class="material-symbols-outlined text-6xl text-primary mb-6"
              >shield_lock</span
            >
            <h3 class="text-white font-serif text-2xl font-bold mb-2">
              Secure Vault
            </h3>
            <p class="text-slate-400 text-sm mb-8">
              Acceso restringido solo para personal autorizado.
            </p>
            <div
              class="w-full bg-background-dark/50 rounded-lg p-4 border border-white/5 flex items-center justify-between mb-3"
            >
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse">
                </div>
                <span class="text-xs text-slate-300 font-mono"
                  >System Online</span
                >
              </div>
              <span class="text-xs text-slate-500 font-mono">v.2.4.0</span>
            </div>
            <div
              class="w-full bg-background-dark/50 rounded-lg p-4 border border-white/5 flex items-center justify-between"
            >
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-slate-400 text-sm"
                  >encrypted</span
                >
                <span class="text-xs text-slate-300 font-mono"
                  >AES-256 Encryption</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<section class="py-24 bg-background-dark relative" id="insights">
  <div class="layout-container px-6 md:px-10 max-w-[1280px] mx-auto">
    <div class="text-center mb-16">
      <span
        class="text-primary text-sm font-bold uppercase tracking-widest mb-2 block"
        >Actualidad Jurídica</span
      >
      <h2 class="font-serif text-3xl md:text-5xl font-bold text-white">
        Alertas Legales &amp; Insights
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        insights.map((insight) => (
          <article class="flex flex-col h-full bg-surface-dark border border-white/5 rounded-lg overflow-hidden hover:border-primary/30 transition-colors group cursor-pointer">
            <div class="p-8 flex flex-col h-full">
              <div class="flex items-center justify-between mb-6">
                <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase">
                  {insight.data.category}
                </span>
                <span class="text-slate-500 text-xs font-medium">
                  {insight.data.date.toLocaleDateString("es-CL", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </span>
              </div>
              <h3 class="font-serif text-xl font-bold text-white mb-4 group-hover:text-primary transition-colors">
                {insight.data.title}
              </h3>
              <p class="text-slate-400 text-sm leading-relaxed mb-8 line-clamp-3">
                {insight.data.description}
              </p>
              <a
                href={`/insights/${insight.slug}`}
                class="mt-auto flex items-center text-white text-sm font-bold group-hover:underline decoration-primary underline-offset-4"
              >
                Leer análisis
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
