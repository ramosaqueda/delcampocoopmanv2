---

---

<section class="relative py-24 bg-background-dark" id="services">
  <div class="layout-container px-6 md:px-10 max-w-[1280px] mx-auto">
    <div
      class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6"
    >
      <div class="max-w-xl">
        <h2
          class="font-serif text-3xl md:text-4xl font-bold text-white mb-4 pl-4 border-l-4 border-primary"
        >
          Áreas de Práctica
        </h2>
        <p class="text-slate-400 text-lg">
          Soluciones legales integrales diseñadas para entornos corporativos
          complejos.
        </p>
      </div>
      <a
        class="hidden md:flex items-center gap-2 text-primary font-bold hover:text-white transition-colors group"
        href="#"
      >
        Ver todos los servicios
        <span
          class="material-symbols-outlined transition-transform group-hover:translate-x-1"
          >arrow_forward</span
        >
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      <div
        class="group relative p-8 rounded-xl bg-surface-dark border border-white/5 hover:border-primary/50 transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,0,0,0.3)] hover:-translate-y-1"
      >
        <div
          class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-xl"
        >
        </div>
        <div class="relative z-10 flex flex-col h-full">
          <div
            class="w-14 h-14 rounded-full bg-background-dark border border-white/10 flex items-center justify-center mb-6 group-hover:border-primary/50 group-hover:bg-primary/10 transition-colors"
          >
            <span class="material-symbols-outlined text-primary text-3xl"
              >verified_user</span
            >
          </div>
          <h3
            class="font-serif text-xl font-bold text-white mb-3 group-hover:text-primary transition-colors"
          >
            Compliance
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-6 flex-grow">
            Diseño e implementación de modelos de prevención de delitos. Gestión
            de riesgos y cumplimiento normativo corporativo bajo estándares
            internacionales.
          </p>
          <div
            class="flex items-center text-accent-silver text-xs font-bold uppercase tracking-wider group-hover:text-primary transition-colors"
          >
            <span>Saber más</span>
            <span class="material-symbols-outlined text-sm ml-2"
              >arrow_right_alt</span
            >
          </div>
        </div>
      </div>
      <div
        class="group relative p-8 rounded-xl bg-surface-dark border border-white/5 hover:border-primary/50 transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,0,0,0.3)] hover:-translate-y-1"
      >
        <div
          class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-xl"
        >
        </div>
        <div class="relative z-10 flex flex-col h-full">
          <div
            class="w-14 h-14 rounded-full bg-background-dark border border-white/10 flex items-center justify-center mb-6 group-hover:border-primary/50 group-hover:bg-primary/10 transition-colors"
          >
            <span class="material-symbols-outlined text-primary text-3xl"
              >gavel</span
            >
          </div>
          <h3
            class="font-serif text-xl font-bold text-white mb-3 group-hover:text-primary transition-colors"
          >
            Litigación Penal
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-6 flex-grow">
            Defensa estratégica en procesos penales de alta complejidad y
            delitos económicos. Representación robusta ante tribunales de
            garantía y orales.
          </p>
          <div
            class="flex items-center text-accent-silver text-xs font-bold uppercase tracking-wider group-hover:text-primary transition-colors"
          >
            <span>Saber más</span>
            <span class="material-symbols-outlined text-sm ml-2"
              >arrow_right_alt</span
            >
          </div>
        </div>
      </div>
      <div
        class="group relative p-8 rounded-xl bg-surface-dark border border-white/5 hover:border-primary/50 transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,0,0,0.3)] hover:-translate-y-1"
      >
        <div
          class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-xl"
        >
        </div>
        <div class="relative z-10 flex flex-col h-full">
          <div
            class="w-14 h-14 rounded-full bg-background-dark border border-white/10 flex items-center justify-center mb-6 group-hover:border-primary/50 group-hover:bg-primary/10 transition-colors"
          >
            <span class="material-symbols-outlined text-primary text-3xl"
              >account_balance</span
            >
          </div>
          <h3
            class="font-serif text-xl font-bold text-white mb-3 group-hover:text-primary transition-colors"
          >
            Derecho Civil
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-6 flex-grow">
            Asesoría experta en conflictos civiles, contractuales y arbitrajes
            comerciales. Resolución de disputas con enfoque en la protección
            patrimonial.
          </p>
          <div
            class="flex items-center text-accent-silver text-xs font-bold uppercase tracking-wider group-hover:text-primary transition-colors"
          >
            <span>Saber más</span>
            <span class="material-symbols-outlined text-sm ml-2"
              >arrow_right_alt</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
